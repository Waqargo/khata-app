<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= category.name %> History | Smart Khata</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
            --brand: #093C5D;
            --bg: #F8F9FA;
            --white: #ffffff;
            --danger: #ff4757;
            --success: #2ed573;
            --border: #edf2f7;
            --text-main: #1a202c;
            --text-muted: #718096;
        }

        body { 
            font-family: 'Inter', sans-serif; 
            background: var(--bg); 
            margin: 0; 
            color: var(--text-main);
            line-height: 1.5;
        }

        .container { max-width: 850px; margin: 30px auto; padding: 0 20px; }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .back-link {
            text-decoration: none;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.9rem;
            font-weight: 500;
        }

        .stat-card {
            background: var(--white);
            padding: 25px;
            border-radius: 20px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
            margin-bottom: 30px;
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .category-icon-big {
            width: 60px;
            height: 60px;
            background: var(--bg);
            border-radius: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
        }

        .transaction-list {
            background: var(--white);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        }

        .t-item {
            display: grid;
            grid-template-columns: auto 1fr auto auto;
            align-items: center;
            padding: 18px 25px;
            gap: 20px;
            border-bottom: 1px solid var(--border);
            transition: background 0.2s;
        }

        .t-item:last-child { border: none; }
        .t-item:hover { background: #fafafa; }

        .t-info h4 { margin: 0; font-size: 1rem; color: var(--text-main); }
        .t-info p { margin: 4px 0 0; font-size: 0.8rem; color: var(--text-muted); }

        .t-amount { font-weight: 700; font-size: 1rem; }
        .t-amount.debit { color: var(--danger); }
        .t-amount.credit { color: var(--success); }

        .actions { display: flex; gap: 10px; }
        .btn-action {
            background: none;
            border: none;
            padding: 8px;
            cursor: pointer;
            border-radius: 8px;
            transition: background 0.2s;
            color: var(--text-muted);
        }

        .btn-action:hover { background: var(--bg); color: var(--brand); }
        .btn-delete:hover { color: var(--danger); }

        /* Modal Styles */
        .modal {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(9, 60, 93, 0.4);
            backdrop-filter: blur(4px);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }

        .modal-card {
            background: var(--white);
            width: 90%;
            max-width: 450px;
            padding: 35px;
            border-radius: 24px;
            box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);
        }

        .form-control { margin-bottom: 20px; }
        .form-control label { display: block; font-size: 0.85rem; font-weight: 600; color: var(--text-muted); margin-bottom: 8px; }
        .modal-input {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid var(--border);
            border-radius: 12px;
            font-family: inherit;
            font-size: 1rem;
            box-sizing: border-box;
        }

        .btn-apply {
            background: var(--brand);
            color: var(--white);
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            cursor: pointer;
        }
    </style>
</head>
<body>
<%- include('partials/navbar') %>
<div class="container">
    <div class="page-header">
        <a href="/dashboard" class="back-link">
            <i data-lucide="arrow-left" style="width: 18px;"></i> Back to Dashboard
        </a>
    </div>

    <div class="stat-card">
        <div class="category-icon-big"><%= category.icon %></div>
        <div>
            <h1 style="margin: 0; font-size: 1.5rem;"><%= category.name %></h1>
            <p style="margin: 5px 0 0; color: var(--text-muted);">History & Analytics</p>
        </div>
    </div>

    <div class="transaction-list">
        <% if (transactions.length === 0) { %>
            <div style="padding: 40px; text-align: center; color: var(--text-muted);">
                <i data-lucide="inbox" style="width: 40px; height: 40px; margin-bottom: 10px;"></i>
                <p>No transactions found.</p>
            </div>
        <% } else { %>
            <% transactions.forEach(t => { %>
                <div class="t-item">
                    <div class="t-info">
                        <h4><%= t.description || 'No description' %></h4>
                        <p><%= new Date(t.date).toLocaleDateString('en-GB') %></p>
                    </div>
                    <div></div>
                    <div class="t-amount <%= t.type.toLowerCase() %>">
                        <%= t.type === 'DEBIT' ? '-' : '+' %> Rs. <%= t.amount.toLocaleString() %>
                    </div>
                    <div class="actions">
                        <button 
                            onclick="openEditModal(this)" 
                            class="btn-action"
                            data-id="<%= t._id %>"
                            data-category="<%= t.category %>"
                            data-type="<%= t.type %>"
                            data-amount="<%= t.amount %>"
                            data-date="<%= t.date %>"
                            data-desc="<%= t.description %>">
                            <i data-lucide="edit-3" style="width: 18px;"></i>
                        </button>
                        <form action="/transactions/delete/<%= t._id %>" method="POST" style="display:inline;" onsubmit="return confirm('Delete this transaction?')">
                            <button class="btn-action btn-delete">
                                <i data-lucide="trash-2" style="width: 18px;"></i>
                            </button>
                        </form>
                    </div>
                </div>
            <% }) %>
        <% } %>
    </div>
</div>

<div id="editModal" class="modal">
    <div class="modal-card">
        <h2 style="color: var(--brand); margin-bottom: 30px;">Edit Transaction</h2>
        <form id="editForm" method="POST">
            
            <div class="form-control">
                <label>Category</label>
                <select name="category" id="editCategory" class="modal-input" required>
                    <% 
                        const parents = categories.filter(c => !c.parent);
                        const children = categories.filter(c => c.parent);
                    %>
                    <% parents.forEach(p => { %>
                        <option value="<%= p._id %>" style="font-weight: bold; background: #f8fafc;">
                            <%= p.icon %> <%= p.name %> (Parent)
                        </option>
                        <% 
                            const myChildren = children.filter(c => c.parent.toString() === p._id.toString());
                            myChildren.forEach(child => { 
                        %>
                            <option value="<%= child._id %>">
                                &nbsp;&nbsp;&nbsp; ↳ <%= child.icon %> <%= child.name %>
                            </option>
                        <% }) %>
                    <% }) %>
                </select>
            </div>

            <div class="form-control">
                <label>Flow Type</label>
                <select name="type" id="editType" class="modal-input">
                    <option value="DEBIT">Debit (Out)</option>
                    <option value="CREDIT">Credit (In)</option>
                </select>
            </div>
            
            <div class="form-control">
                <label>Amount (PKR)</label>
                <input type="number" name="amount" id="editAmount" class="modal-input" required>
            </div>

            <div class="form-control">
                <label>Date</label>
                <input type="date" name="date" id="editDate" class="modal-input" required>
            </div>

            <div class="form-control">
                <label>Note / Description</label>
                <textarea name="description" id="editDesc" class="modal-input" rows="3"></textarea>
            </div>

            <div style="display: flex; gap: 15px; margin-top: 30px;">
                <button type="submit" class="btn-apply" style="flex: 2;">Save Updates</button>
                <button type="button" onclick="closeModal()" class="btn-apply" style="flex: 1; background: var(--bg); color: var(--text-muted);">Cancel</button>
            </div>
        </form>
    </div>
</div>

<script>
    lucide.createIcons();

    function openEditModal(btn) {
        const modal = document.getElementById('editModal');
        const form = document.getElementById('editForm');
        
        const id = btn.getAttribute('data-id');
        const category = btn.getAttribute('data-category');
        const type = btn.getAttribute('data-type');
        const amount = btn.getAttribute('data-amount');
        const desc = btn.getAttribute('data-desc');
        const dateRaw = btn.getAttribute('data-date');

        form.action = `/transactions/edit/${id}`;
        
        document.getElementById('editCategory').value = category;
        document.getElementById('editType').value = type;
        document.getElementById('editAmount').value = amount;
        document.getElementById('editDesc').value = desc;
        
        if (dateRaw) {
            document.getElementById('editDate').value = new Date(dateRaw).toISOString().split('T')[0];
        }

        modal.style.display = 'flex';
    }

    function closeModal() { 
        document.getElementById('editModal').style.display = 'none'; 
    }

    window.onclick = function(e) {
        if (e.target == document.getElementById('editModal')) closeModal();
    }
</script>

</body>
</html>
