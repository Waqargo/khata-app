<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= parent.name %> | Smart Khata</title>
    <style>
        :root {
            --brand: #093C5D;
            --bg-light: #F5F5F5;
            --white: #ffffff;
            --danger: #ff4757;
            --success: #2ed573;
            --text: #2d3436;
        }

        body { 
            font-family: 'Inter', sans-serif; 
            background: var(--bg-light); 
            margin: 0; 
            color: var(--text);
        }

        .container { max-width: 800px; margin: 40px auto; padding: 0 20px; }

        /* Elegant Breadcrumb */
        .btn-back { 
            display: inline-flex; 
            align-items: center; 
            margin-bottom: 25px; 
            color: var(--brand); 
            text-decoration: none; 
            font-weight: 700; 
            font-size: 0.9rem;
            transition: 0.3s;
            opacity: 0.7;
        }
        .btn-back:hover { opacity: 1; transform: translateX(-5px); }

        /* Dynamic Header Card */
        .parent-header {
            background: var(--brand);
            color: white;
            padding: 50px 40px;
            border-radius: 30px;
            text-align: center;
            margin-bottom: 40px;
            box-shadow: 0 15px 35px rgba(9, 60, 93, 0.12);
            position: relative;
            overflow: hidden;
        }
        
        .parent-header::before {
            content: ''; position: absolute; top: -20%; right: -10%; 
            width: 200px; height: 200px; background: rgba(255,255,255,0.05); 
            border-radius: 50%;
        }

        .parent-header .icon-box { 
            width: 80px; height: 80px; 
            background: rgba(255,255,255,0.1); 
            border-radius: 24px;
            display: flex; align-items: center; justify-content: center;
            font-size: 2.5rem; margin: 0 auto 20px;
        }
        
        .parent-header h1 { margin: 0; font-size: 1.8rem; font-weight: 800; letter-spacing: -0.5px; }
        .parent-header .total-label { opacity: 0.6; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1.5px; margin-top: 25px; font-weight: 700; }
        .parent-header .main-balance { font-size: 3.2rem; font-weight: 800; margin-top: 5px; }

        /* List Styling */
        .section-title { 
            font-size: 1rem; 
            text-transform: uppercase; 
            letter-spacing: 1px; 
            font-weight: 800; 
            margin-bottom: 20px; 
            color: var(--brand);
            opacity: 0.8;
        }

        .child-list { display: flex; flex-direction: column; gap: 15px; }
        
        .category-item {
            background: var(--white);
            padding: 24px;
            border-radius: 20px;
            text-decoration: none;
            color: inherit;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: 1px solid rgba(0,0,0,0.02);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 4px 6px rgba(0,0,0,0.01);
        }
        
        .category-item:hover { 
            transform: translateY(-4px); 
            box-shadow: 0 12px 25px rgba(9, 60, 93, 0.08);
            border-color: var(--brand);
        }
        
        .cat-info { display: flex; align-items: center; gap: 18px; }
        .cat-info .icon-bg { 
            width: 48px; height: 48px; 
            background: var(--bg-light); 
            border-radius: 14px; 
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem; 
        }
        .cat-info .name { font-weight: 700; font-size: 1.1rem; color: var(--brand); }
        .cat-info .sub-text { display: block; font-size: 0.75rem; color: #999; font-weight: 500; }
        
        .cat-amount { text-align: right; }
        .amount-val { font-weight: 800; font-size: 1.2rem; display: block; }
        .negative { color: var(--danger); }
        .positive { color: var(--success); }

        .chevron { color: #ccc; margin-left: 15px; transition: 0.3s; }
        .category-item:hover .chevron { color: var(--brand); transform: translateX(3px); }
    </style>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body>

<%- include('partials/navbar') %>

<div class="container">
    <a href="/dashboard" class="btn-back">
        <i data-lucide="chevron-left" style="width: 18px; margin-right: 5px;"></i> Back to Portfolio
    </a>

    <div class="parent-header">
        <div class="icon-box"><%= parent.icon %></div>
        <h1><%= parent.name %></h1>
        <div class="total-label">Consolidated Balance</div>
        <div class="main-balance" style="color: <%= totalRollup < 0 ? '#ffb8b8' : '#63ffda' %>">
            Rs. <%= totalRollup.toLocaleString() %>
        </div>
    </div>

    <h2 class="section-title">Account Breakdown</h2>
    <div class="child-list">
        
        <!-- Parent Direct Entries -->
        <a href="/transactions/<%= parent._id %>" class="category-item">
            <div class="cat-info">
                <div class="icon-bg">🏠</div>
                <div>
                    <span class="name">Direct Entries</span>
                    <span class="sub-text">Primary <%= parent.name %> log</span>
                </div>
            </div>
            <div style="display: flex; align-items: center;">
                <div class="cat-amount">
                    <% const pb = balanceMap[parent._id.toString()] || 0; %>
                    <span class="amount-val <%= pb < 0 ? 'negative' : 'positive' %>">
                        Rs. <%= pb.toLocaleString() %>
                    </span>
                </div>
                <i data-lucide="chevron-right" class="chevron"></i>
            </div>
        </a>

        <!-- Sub Categories -->
        <% children.forEach(child => { %>
            <% const b = balanceMap[child._id.toString()] || 0; %>
            <a href="/transactions/<%= child._id %>" class="category-item">
                <div class="cat-info">
                    <div class="icon-bg"><%= child.icon %></div>
                    <div>
                        <span class="name"><%= child.name %></span>
                        <span class="sub-text">Sub-category account</span>
                    </div>
                </div>
                <div style="display: flex; align-items: center;">
                    <div class="cat-amount">
                        <span class="amount-val <%= b < 0 ? 'negative' : 'positive' %>">
                            Rs. <%= b.toLocaleString() %>
                        </span>
                    </div>
                    <i data-lucide="chevron-right" class="chevron"></i>
                </div>
            </a>
        <% }) %>
    </div>
</div>

<script>
    lucide.createIcons();
</script>

</body>
</html>